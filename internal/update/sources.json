{
  "default_manifest_source": "manifest_cource",
  "default_download_source": "manifest_cource",
  "manifest_sources": [
    {
      "id": "manifest_cource",
      "name": "Manifest Cource",
      "type": "manifest",
      "url": "https://manifest.xuetao.host/LDM/latest.json",
      "timeout_seconds": 8,
      "supports_remote_packages": true
    },
    {
      "id": "github-release",
      "name": "GitHub Releases",
      "type": "github",
      "repo": "LoranaAurelia/LDManager",
      "asset_name_contains": "ldm-linux-{arch}",
      "timeout_seconds": 8
    }
  ],
  "download_sources": [
    {
      "id": "github-release",
      "name": "GitHub Release Assets",
      "arch_urls": {
        "amd64": "https://github.com/LoranaAurelia/LDManager/releases/latest/download/ldm-linux-amd64",
        "arm64": "https://github.com/LoranaAurelia/LDManager/releases/latest/download/ldm-linux-arm64"
      }
    }
  ]
}
